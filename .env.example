# ---- LLM (Anthropic / Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- LangSmith tracing & observability ----
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=flight-multi-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Flight data provider: Amadeus Self-Service ----
# Get free test keys at https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test            # 'test' (sandbox) or 'production'

# ---- Alternative provider: SerpAPI (Google Flights) ----
SERPAPI_API_KEY=your_serpapi_key

# ---- Weather provider: OpenWeatherMap ----
OPENWEATHER_API_KEY=your_openweather_key
